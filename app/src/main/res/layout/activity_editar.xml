<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <TextView
        android:id="@+id/txtTituloActivityEditar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Editar Tarefa"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/lblDescricaoEditar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Descrição da Tarefa:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/txtTituloActivityEditar"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/edtDescricaoEditar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="O que precisa ser feito?"
        android:inputType="textMultiLine"
        android:gravity="top"
        android:lines="3"
        android:minHeight="48dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/lblDescricaoEditar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/lblResponsavelEditar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Responsável:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/edtDescricaoEditar"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/edtResponsavelEditar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Nome de quem vai fazer"
        android:inputType="textPersonName"
        android:minHeight="48dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/lblResponsavelEditar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/lblStatusEditar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Progresso da Tarefa:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/edtResponsavelEditar"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_porcentagemEditar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0%"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/lblStatusEditar"
        app:layout_constraintBottom_toBottomOf="@id/lblStatusEditar"
        app:layout_constraintEnd_toEndOf="parent" />

    <SeekBar
        android:id="@+id/seekBar_statusEditar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:max="100"
        app:layout_constraintTop_toBottomOf="@id/lblStatusEditar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnSalvarEdicao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Salvar Alterações"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>